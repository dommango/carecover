// CareCover data model. See docs/superpowers/specs for the design.
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ClaimRule {
  PARTIAL
  WHOLE_GAP
}

enum WindowStatus {
  OPEN
  FILLED
  CLOSED
  EXPIRED
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

// A person in the global directory. Tier membership is per-window (WindowTierMember),
// not a property of the person.
model Respondent {
  id        String   @id @default(cuid())
  name      String
  phone     String // E.164
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  assignments     Assignment[]
  tokens          ResponseToken[]
  notifications   NotificationLog[]
  tierMemberships WindowTierMember[]

  @@index([active])
}

model Window {
  id        String       @id @default(cuid())
  startsAt  DateTime
  endsAt    DateTime
  notes     String       @default("")
  status    WindowStatus @default(OPEN)
  // Index into the ordered `tiers` of the tier currently (and most recently) opened.
  activeTierIndex Int    @default(0)
  // Denormalized deadline of the active tier — when it passes, escalate to the next
  // tier. Null once the last tier is active (no further escalation). Single source of
  // truth maintained only by createWindow / runDeadlineEscalation.
  currentTierDeadlineAt DateTime?
  createdAt DateTime     @default(now())

  tiers         WindowTier[]
  assignments   Assignment[]
  tokens        ResponseToken[]
  notifications NotificationLog[]

  @@index([status, currentTierDeadlineAt])
}

// One rung of a window's escalation ladder. Ordered by `position` (0 = contacted first).
model WindowTier {
  id              String    @id @default(cuid())
  window          Window    @relation(fields: [windowId], references: [id], onDelete: Cascade)
  windowId        String
  position        Int
  label           String?
  claimRule       ClaimRule
  minShiftMinutes Int       @default(240) // WHOLE_GAP only; ignored for PARTIAL
  // Absolute instant this tier escalates to the next. startsAt − leadHours at creation.
  // Null for the last tier (terminal; stays claimable, never escalates).
  deadlineAt      DateTime?
  createdAt       DateTime  @default(now())

  members     WindowTierMember[]
  tokens      ResponseToken[]
  assignments Assignment[]

  @@unique([windowId, position])
}

// Which people belong to a given window-tier.
model WindowTierMember {
  id           String     @id @default(cuid())
  windowTier   WindowTier @relation(fields: [windowTierId], references: [id], onDelete: Cascade)
  windowTierId String
  respondent   Respondent @relation(fields: [respondentId], references: [id], onDelete: Cascade)
  respondentId String

  @@unique([windowTierId, respondentId])
}

// A covered block. Coverage = window interval minus union of assignments.
// Remaining gaps are always derived, never stored.
model Assignment {
  id           String      @id @default(cuid())
  window       Window      @relation(fields: [windowId], references: [id], onDelete: Cascade)
  windowId     String
  respondent   Respondent  @relation(fields: [respondentId], references: [id])
  respondentId String
  // The tier that filled this block. Null for admin manual assignments (no tier).
  // Restrict: assignments are coverage history; a tier can't be deleted out from under one.
  windowTier   WindowTier? @relation(fields: [windowTierId], references: [id], onDelete: Restrict)
  windowTierId String?
  startsAt     DateTime
  endsAt       DateTime
  claimedAt    DateTime    @default(now())

  @@index([windowId])
}

// Embedded in the SMS link so the response page identifies who + which window-tier
// without any login. Token stored hashed at rest.
model ResponseToken {
  id           String     @id @default(cuid())
  window       Window     @relation(fields: [windowId], references: [id], onDelete: Cascade)
  windowId     String
  respondent   Respondent @relation(fields: [respondentId], references: [id])
  respondentId String
  windowTier   WindowTier @relation(fields: [windowTierId], references: [id], onDelete: Cascade)
  windowTierId String
  tokenHash    String     @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime   @default(now())

  @@unique([windowId, respondentId, windowTierId])
}

model NotificationLog {
  id                String             @id @default(cuid())
  window            Window?            @relation(fields: [windowId], references: [id], onDelete: SetNull)
  windowId          String?
  respondent        Respondent?        @relation(fields: [respondentId], references: [id])
  respondentId      String?
  channel           String             @default("sms")
  body              String
  providerMessageId String?
  status            NotificationStatus @default(QUEUED)
  error             String?
  sentAt            DateTime           @default(now())

  @@index([windowId])
}
