# Copy to .env and fill in. In production set these as Railway env vars.

# Postgres connection string (Railway provides this for the Postgres plugin)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Display/entry timezone for all windows
APP_TIMEZONE="America/New_York"

# Public base URL of the app (used to build SMS response links)
APP_BASE_URL="https://your-app.up.railway.app"

# Single-admin login password + secret used to sign the session cookie (>=32 chars)
ADMIN_PASSWORD="set-a-strong-password"
SESSION_SECRET="set-a-long-random-secret-at-least-32-chars"

# Default hours given to tier-1 before escalation, when not set per-window
TIER1_DEFAULT_DEADLINE_HOURS="12"

# Shared secret the Railway cron job sends in the x-cron-secret header
CRON_SECRET="set-a-random-secret"

# Twilio — if any are blank, SMS is logged to the DB instead of sent (safe for dev)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER="+1XXXXXXXXXX"
